{
  "expo": {
    "name": "7-Day Minimal Life",
    "slug": "minimal-life",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "minimal-life",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.minimalnomad.minimallife"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.minimalnomad.minimallife"
    },
    "plugins": ["expo-router", "expo-font", "expo-sqlite"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fdc3a66a-e535-415c-8a36-d0508f96086a"
      }
    },
    "owner": "tonozero",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fdc3a66a-e535-415c-8a36-d0508f96086a"
    }
  }
}
